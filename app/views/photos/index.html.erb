<h1>写真一覧</h1>

<p style="color: red"><%= alert %></p>
<p style="color: green"><%= notice %></p>

<p>
  <%= link_to "tweet app連携", oauth_authorize_path %>
</p>
<p>
  <%= link_to "写真アップロード", new_photo_path %>
</p>

<% if @photos.any? %>
  <div style="display: flex; flex-wrap: wrap; gap: 24px;">
  <% @photos.each do |photo| %>
    <div style="margin-bottom: 24px;">
      <% if photo.title.present? %>
        <h2><%= photo.title %></h2>
      <% end %>

      <% if photo.image.attached? %>
        <%= image_tag photo.image, style: "max-width: 300px; height: auto;" %>
      <% end %>

      <% if session[:access_token].present? %>
        <p>
          <%= link_to "ツイートする", tweet_photo_path(photo), data: { turbo_method: :post } %>
        </p>
      <% end %>
    </div>
  <% end %>
  </div>
<% else %>
  <p>まだ写真がありません。</p>
<% end %>

<%= link_to "ログアウト", session_path, data: { turbo_method: :delete } %>